# PostgreSQL（生产：Supabase；本地：先 docker compose up -d）
DATABASE_URL="postgresql://xinshiye:xinshiye_dev@127.0.0.1:5432/xinshiye"
# Supabase 直连（Prisma migrate 用；Vercel 生产环境需配置）
DIRECT_URL="postgresql://xinshiye:xinshiye_dev@127.0.0.1:5432/xinshiye"

# 会话签名（至少 32 字符随机串）
SESSION_SECRET="replace-with-openssl-rand-hex-32"

# 种子演示账号密码（至少 12 字符；仅用于本地开发）
SEED_DEMO_PASSWORD="replace-with-strong-dev-password"

# 站点 URL（用于 metadata / 绝对链接）
NEXT_PUBLIC_SITE_URL="http://localhost:3002"
